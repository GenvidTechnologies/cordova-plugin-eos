<plugin xmlns="http://apache.org/cordova/ns/plugins/1.0"
    xmlns:rim="http://www.blackberry.com/ns/widgets"
    xmlns:android="http://schemas.android.com/apk/res/android"
    id="cordova-plugin-eos"
    version="1.2.0">
    <name>EOS</name>
    <description>Cordova Epic Online Services Plugin</description>
    <license>MIT-0</license>
    <keywords>cordova,eos</keywords>
    <repo>https://bitbucket.org/genvidtech/cordova-plugin-eos</repo>
    <issue>https://bitbucket.org/genvidtech/cordova-plugin-eos/issues</issue>

    <engines>
        <engine name="cordova-android" version=">=7.0.0" />
    </engines>

    <js-module src="www/eos.js" name="eos">
        <clobbers target="window.plugins.eos" />
    </js-module>
    <js-module src="www/auth.js" name="auth"></js-module>
    <js-module src="www/ecom.js" name="ecom"></js-module>
    <js-module src="www/error.js" name="error"></js-module>

    <!-- TODO: Use a more useful way to pass those arguments -->
    <info>
        Your environment should contains this variable:
        EOS_SDK_PATH=path/to/android/sdk/installation/SDK
    </info>

    <!-- android -->
    <platform name="android">

        <config-file target="res/xml/config.xml" parent="/*">
            <feature name="EOS">
                <param name="android-package" value="com.genvidtech.cordova.eos.CordovaEOS" />
            </feature>
        </config-file>

        <source-file src="src/android/CordovaEOS.java"
            target-dir="src/com/genvidtech/cordova/eos/" />
        <source-file src="src/android/cpp/CordovaEOS/CordovaEOS.cpp"
            target-dir="cpp/CordovaEOS/" />
        <source-file src="src/android/cpp/CordovaEOS/CMakeLists.txt"
            target-dir="cpp/CordovaEOS/" />

        <framework src="src/android/build.gradle" custom="true" type="gradleReference" />
    </platform>

    <!-- ios -->
    <platform name="ios">
        <config-file target="config.xml" parent="/*">
            <feature name="EOS">
                <param name="ios-package" value="CordovaEOS" />
            </feature>
        </config-file>
        <hook type="before_plugin_install" src="scripts/install_eos_framework.js" />
        <framework src="src/ios/EOSSDK.framework" custom="true" embed="true" link="true" />
        <framework src="AuthenticationServices.framework" />
        <header-file src="src/ios/CordovaEOS.h" />
        <source-file src="src/ios/CordovaEOS.mm" />
        <header-file src="src/ios/EOSWrapper.h" />
        <source-file src="src/ios/EOSWrapper.mm" />
        <header-file src="src/ios/ReservedPlatformOptions.h" />
        <source-file src="src/ios/ReservedPlatformOptions.mm" />
    </platform>

</plugin>